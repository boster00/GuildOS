# -----------------------------------------------------------------------------
# Resend: https://shipfa.st/docs/features/emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Metering: testing quota override (all users get this monthly credit quota)
# Set METERING_TEST_QUOTA=10000 for testing; 100 or unset for beta/production
# -----------------------------------------------------------------------------
METERING_TEST_QUOTA=10000

# Quota is OFF by default (no "Monthly quota exceeded"). To enforce quota, set:
# ENABLE_METERING=true
# To explicitly bypass when needed: DISABLE_METERING=true

# -----------------------------------------------------------------------------
# Cron & Master of Coins (monthly credit resets)
# Vercel cron calls /api/cron/trigger which invokes the MoC worker. Set at least one secret.
# -----------------------------------------------------------------------------
# CRON_SECRET=
# MASTER_OF_COINS_SECRET=

# -----------------------------------------------------------------------------
# Site URL (used by cron/MoC worker to call back the app; e.g. https://yourapp.vercel.app)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=
# SITE_URL=

# -----------------------------------------------------------------------------
# Admin: unlimited quota for this email when ADMIN_UNLIMITED_QUOTA=true
# Admin routes (e.g. /api/admin/credits/adjust, /api/admin/users) require email in allowlist.
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS=admin@example.com,other@example.com
# ADMIN_UNLIMITED_QUOTA=true